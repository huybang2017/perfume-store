# Copy to .env.production and fill with strong secrets before deploy

# PostgreSQL
POSTGRES_DB=clothing_store
POSTGRES_USER=clothing_prod
POSTGRES_PASSWORD=change-me-strong-db-password

# Redis
REDIS_PASSWORD=change-me-strong-redis-password

# Backend (JWT must be at least 32 characters)
JWT_SECRET=change-me-use-openssl-rand-base64-32-output-here
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://your-domain.com
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Cloudinary (required for product image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend build args (public URLs)
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
NEXT_PUBLIC_WS_URL=https://api.your-domain.com
