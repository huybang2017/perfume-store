# Development — copy to backend/.env and adjust

# Backend
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://clothing:clothing@localhost:5432/clothing_store
REDIS_HOST=localhost
REDIS_PORT=6379
# Must be at least 32 characters (required by validation)
JWT_SECRET=clothing-store-dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
FRONTEND_URL=http://localhost:3000
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# One-time bootstrap: POST /api/v1/auth/make-admin { email, secret }
ADMIN_SETUP_SECRET=change-me-admin-setup-secret-min-8-chars
THROTTLE_AUTH_LIMIT=10

# Cloudinary (required for product image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Thanh toán Việt Nam
BANK_NAME=Vietcombank
BANK_ACCOUNT=0123456789
BANK_HOLDER=CONG TY TNHH CLOTHIFY
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/thanh-toan/ket-qua
VNPAY_IPN_URL=http://localhost:4000/api/v1/payments/vnpay/ipn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/thanh-toan/ket-qua
MOMO_IPN_URL=http://localhost:4000/api/v1/payments/momo/ipn

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clothingstore.com

# Frontend (frontend/.env.local) — proxied through Next.js in development
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
API_URL=http://localhost:4000
