{
  "name": "clothing-store",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise clothing e-commerce platform (NestJS + Next.js)",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "test:api": "node scripts/test-all-apis.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
